{
  "languages": {
    "Rust": {
      "formatter": "language_server",
      "format_on_save": "on",
    },
    "TOML": {
      "format_on_save": "on",
    },
    "Markdown": {
      "format_on_save": "on",
      "formatter": "prettier",
    },
  },
  "lsp": {
    "rust-analyzer": {
      "enable_lsp_tasks": true,
      "initialization_options": {
        "check": {
          "command": "clippy",
          "workspace": true,
          "extraArgs": ["--release", "--target", "thumbv7em-none-eabihf", "--features", "ansi_layout"],
        },
        "rustfmt": {
          "extraArgs": ["+nightly"],
        },
        "cargo": {
          "features": ["ansi_layout"],
          "target": "thumbv7em-none-eabihf",
        },
        "inlayHints": {
          "maxLength": null,
          "lifetimeElisionHints": {
            "enable": "always",
            "useParameterNames": true,
          },
          "closureReturnTypeHints": {
            "enable": "always",
          },
        },
        "diagnostics": {
          "experimental": {
            "enable": true,
          },
        },
        "rust": {
          "analyzerTargetDir": true,
        },
      },
    },
  },
}
